# 鈹€鈹€ 鍥炴函鍒嗘瀽鏁版嵁锛堝姞杞斤級 鈹€鈹€
BACKTEST_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'backtest_result.json')
