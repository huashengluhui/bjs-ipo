# 鈹€鈹€ 鏃堕棿宸ュ叿 鈹€鈹€
def next_minute(t: str) -> str:
    """杩斿洖 t 涔嬪悗鐨勪笅涓€涓氦鏄撳垎閽燂紝濡?'09:30'鈫?09:31'锛?11:30'鈫?13:01'锛?15:00'鈫扤one"""
    h, m = map(int, t.split(':'))
    if t == '15:00':
        return None
    total = h * 60 + m
    total += 1
    if total == 11 * 60 + 31:
        return '13:01'
    h2, m2 = divmod(total, 60)
    return f'{h2:02d}:{m2:02d}'

def is_lunch_boundary(prev_t: str, next_t: str) -> bool:
    """璺ㄥ崍浼戣竟鐣岋紙11:30鈫?3:01锛変笉绠楃己澶?""
    return prev_t == '11:30' and next_t == '13:01'

def time_to_elapsed(time_str: str) -> int:
    """'HH:MM' 鈫?寮€鐩樿窛浠婂垎閽熸暟"""
    h, m = map(int, time_str.split(':'))
    if h < 13:
        elapsed = (h - 9) * 60 + m - 30
    else:
        elapsed = (h - 13) * 60 + m + 120
    return max(0, elapsed)

def ema(values, period):
    """鎸囨暟绉诲姩鍧囩嚎"""
    if len(values) < period:
        return values[-1] if values else 0
    k = 2 / (period + 1)
    result = sum(values[:period]) / period
    for v in values[period:]:
        result = v * k + result * (1 - k)
    return result

