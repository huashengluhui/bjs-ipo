def fill_gaps(data):
    """琛ュ叏鍒嗛挓鏁版嵁涓棿鐨勭己澶憋紙璺ㄥ崍浼戦櫎澶栵級锛岀敤鍓嶄竴鏍圭殑 close 濉厖"""
    if len(data) < 2:
        return data
    filled = [data[0]]
    for i in range(1, len(data)):
        prev_t = filled[-1]['time']
        curr_t = data[i]['time']
        expected = next_minute(prev_t)
        while expected and expected != curr_t and not is_lunch_boundary(prev_t, expected):
            filled.append({
                'time': expected,
                'open': filled[-1]['close'],
                'high': filled[-1]['close'],
                'low': filled[-1]['close'],
                'close': filled[-1]['close'],
                'vol': 0,
                'amount': 0,
                'cum_vol': filled[-1]['cum_vol'],
                'turnover': filled[-1]['turnover'],
            })
            prev_t = expected
            expected = next_minute(expected)
        filled.append(data[i])
    return filled

@app.route('/api/data')
def get_data():
    with lock:
        latest = minute_data[-1] if minute_data else None
        if latest:
            latest['prev_close'] = prev_close
        return {
            'code': STOCK_CODE,
            'name': STOCK_NAME,
            'circulating': CIRCULATING_SHARES,
            'latest': latest,
            'data': fill_gaps(minute_data),
            'avg_turnover': AVG_TURNOVER,
        }


@app.route('/api/ping')
def get_ping():
    return {'ok': True}

@app.route('/api/risk')
def get_risk():
    """杩斿洖瀹炴椂鍗栧嚭椋庨櫓璇勫垎"""
    with lock:
        data = list(minute_data)  # shallow copy
    if not data:
        return {'score': 50, 'signals': [], 'summary': '鏃犳暟鎹?}
    result = compute_risk_score(data, prev_close)
    return result


def build_recommendation(bars, indicators, similar, now_price, vwap, current_to, intraday_high, high_time, now_elapsed, current_vol, now_time):
    """缁煎悎鏂规C鎸囨爣 + 鏂规B鐩镐技搴?鈫?鍗栧嚭寤鸿"""
    # 浠?indicators 鎻愬彇淇″彿
    sig_map = {}
    for ind in indicators:
        sig_map[ind['id']] = ind

    checklist = []
    sell_score = 0  # 姣忔潯婊¤冻 +1锛?3 瑙﹀彂鍗栧嚭

    # 1. 鎹㈡墜鐜囧垽鏂?
    if current_to >= 85:
        checklist.append({'check': '鎹㈡墜鐜?> 85%', 'triggered': True, 'detail': f'鎹㈡墜鐜噞current_to:.1f}%宸查ケ鍜岋紝涔扮洏鏋', 'weight': 2})
        sell_score += 2
    elif current_to >= 70:
        checklist.append({'check': '鎹㈡墜鐜?> 70%', 'triggered': True, 'detail': f'鎹㈡墜鐜噞current_to:.1f}%杩涘叆椋庨櫓鍖?, 'weight': 1})
        sell_score += 1
    else:
        checklist.append({'check': '鎹㈡墜鐜?> 70%', 'triggered': False, 'detail': f'鎹㈡墜鐜噞current_to:.1f}%锛屼粛鍦ㄥ畨鍏ㄥ尯'})

    # 2. VWAP鍋忕
    vwap_dev = (now_price - vwap) / vwap * 100 if vwap > 0 else 0
    if vwap_dev > 8:
        checklist.append({'check': 'VWAP鍋忕 > 8%', 'triggered': True, 'detail': f'鍋忕{vwap_dev:+.1f}%锛屼环鏍艰繙楂樹簬鍧囦环锛屾场娌俊鍙?, 'weight': 1})
        sell_score += 1
    elif vwap_dev > 5:
        checklist.append({'check': 'VWAP鍋忕 > 5%', 'triggered': True, 'detail': f'鍋忕{vwap_dev:+.1f}%锛屽亸楂橈紝鍏虫敞鍥炶惤', 'weight': 1})
        sell_score += 1
    else:
        checklist.append({'check': 'VWAP鍋忕姝ｅ父', 'triggered': False, 'detail': f'鍋忕{vwap_dev:+.1f}%锛屼环鏍煎洿缁曞潎浠锋尝鍔?})

    # 3. MACD姝诲弶
    macd_sig = sig_map.get('macd', {})
    if macd_sig.get('signal') == 'dead':
        checklist.append({'check': 'MACD姝诲弶', 'triggered': True, 'detail': '鐭湡EMA璺岀牬涓湡EMA锛岃秼鍔胯浆寮?, 'weight': 1})
        sell_score += 1
    else:
        checklist.append({'check': 'MACD閲戝弶/澶氬ご', 'triggered': False, 'detail': '鐭湡瓒嬪娍鍚戜笂'})

    # 4. 鎴愪氦閲忚剦鍐?(鏀鹃噺涓嬭穼)
    vol_anom = sig_map.get('volume_anomaly', {})
    # 闇€瑕佹鏌ユ渶杩戜竴鏍规槸鍚︽斁閲忎笖浠锋牸涓嬭穼
    if len(bars) >= 2:
        last_close = bars[-1]['close']
        prev_close = bars[-2]['close']
        vol_spike = vol_anom.get('signal') == 'volume_spike'
        price_drop = last_close < prev_close
        if vol_spike and price_drop:
            checklist.append({'check': '鏀鹃噺涓嬭穼', 'triggered': True, 'detail': f'鎴愪氦閲忚剦鍐瞷vol_anom.get("value",0)}x + 浠锋牸涓嬭穼锛屼富鍔涘嚭璐т俊鍙?, 'weight': 2})
            sell_score += 2
        elif vol_spike:
            checklist.append({'check': '鎴愪氦閲忚剦鍐?, 'triggered': True, 'detail': f'鎴愪氦閲弡vol_anom.get("value",0)}x鍧囧€硷紝闇€鍏虫敞鏂瑰悜', 'weight': 1})
            sell_score += 1
        else:
            checklist.append({'check': '鏃犲紓甯告斁閲?, 'triggered': False, 'detail': '鎴愪氦閲忓钩绋?})
    else:
        checklist.append({'check': '鏃犲紓甯告斁閲?, 'triggered': False, 'detail': '鏁版嵁绉疮涓?})

    # 5. 5鍒嗛挓鍔ㄩ噺鎬ヨ穼
    mom5_sig = sig_map.get('momentum_5min', {})
    mom5_val = mom5_sig.get('value', 0)
    if mom5_val < -1.5:
        checklist.append({'check': '5鍒嗛挓鎬ヨ穼', 'triggered': True, 'detail': f'5鍒嗛挓璺寋mom5_val:+.1f}%锛岀煭鏈熸亹鎱?, 'weight': 1})
        sell_score += 1
    else:
        checklist.append({'check': '5鍒嗛挓鍔ㄩ噺', 'triggered': False, 'detail': f'鍙樺寲{mom5_val:+.1f}%锛?鍒嗛挓鍐呮尝鍔ㄥ彲鎺?})

    # 6. 鎹㈡墜鐜囧噺閫燂紙鍒伴《淇″彿锛?
    to_sig = sig_map.get('turnover_speed', {})
    to_sig_val = to_sig.get('signal', '')
    if to_sig_val == 'decelerating' and current_to >= 70:
        checklist.append({'check': '鎹㈡墜鍑忛€?楂樻崲鎵?, 'triggered': True, 'detail': '鎹㈡墜閫熷害鏀剧紦涓斿凡瓒?0%锛屼拱鐩樿€楀敖鍙兘', 'weight': 2})
        sell_score += 2
    elif to_sig_val == 'decelerating':
        checklist.append({'check': '鎹㈡墜鐜囧噺閫?, 'triggered': True, 'detail': '鎹㈡墜鑺傚鏀剧紦锛屼氦鎶曠儹搴︿笅闄?, 'weight': 1})
        sell_score += 1
    else:
        checklist.append({'check': '鎹㈡墜閫熷害姝ｅ父', 'triggered': False, 'detail': '鎹㈡墜鑺傚绋冲畾鎴栧姞閫?})

    # 7. 鏃ュ唴楂樼偣鍥炴挙
    dd_from_high = (intraday_high - now_price) / intraday_high * 100 if intraday_high > 0 else 0
    if dd_from_high > 15:
        checklist.append({'check': '浠庨珮鐐瑰洖鎾?> 15%', 'triggered': True, 'detail': f'宸蹭粠鏈€楂榹intraday_high:.2f}鍥炶惤{dd_from_high:.1f}%锛岃椤舵鐜囬珮', 'weight': 2})
        sell_score += 2
    elif dd_from_high > 8:
        checklist.append({'check': '浠庨珮鐐瑰洖鎾?> 8%', 'triggered': True, 'detail': f'鍥炶惤{dd_from_high:.1f}%锛岃穼鍔垮彲鑳藉欢缁?, 'weight': 1})
        sell_score += 1
    else:
        checklist.append({'check': '璺濋珮鐐硅緝杩?, 'triggered': False, 'detail': f'璺濇渶楂樼偣浠呭洖钀絳dd_from_high:.1f}%'})

    # 鈹€鈹€ 鏂规B鍔犳垚 鈹€鈹€
    b_bonus = ''
    if similar:
        best = similar[0]
        if best['correlation'] > 0.6:
            b_bonus = f'鏈€鐩镐技{best["code"]}{best["name"]}(r={best["correlation"]:.2f})棣栨棩鏀剁洏娑▄best["final_gain"]:.0f}%锛岀洏涓渶楂榹best["max_gain"]:.0f}%'

    # 鈹€鈹€ 鍐崇瓥 鈹€鈹€
    triggered = sum(1 for c in checklist if c['triggered'])
    if sell_score >= 5:
        action = 'sell_now'
        label = '馃敶 寮虹儓寤鸿鍗栧嚭'
        advice = '澶氫釜鍗栧嚭淇″彿鍚屾椂瑙﹀彂锛屽缓璁珛鍗冲噺浠撴垨娓呬粨'
        color = '#ef4444'
        bg = 'rgba(239,68,68,0.12)'
    elif sell_score >= 3:
        action = 'sell_soon'
        label = '馃煚 鍑嗗鍗栧嚭'
        advice = '瑙﹀彂{}鏉″崠鍑轰俊鍙凤紝寤鸿鍦ㄦ帴涓嬫潵鍑犲垎閽熷唴鍒嗘壒鍗栧嚭'.format(triggered)
        color = '#f97316'
        bg = 'rgba(249,115,22,0.12)'
    elif sell_score >= 2:
        action = 'watch_close'
        label = '馃煛 瀵嗗垏鍏虫敞'
        advice = '鏈墈}鏉′俊鍙疯Е鍙戯紝寤鸿绱х洴璧板娍'.format(triggered)
        color = '#fbbf24'
        bg = 'rgba(251,191,36,0.10)'
    else:
        action = 'hold'
        label = '馃煝 鏆傛寔瑙傛湜'
        advice = '褰撳墠鏃犳槑鏄惧崠鍑轰俊鍙凤紝鍙互缁х画鎸佹湁瑙傚療'
        color = '#22c55e'
        bg = 'rgba(34,197,94,0.10)'

    return {
        'action': action,
        'label': label,
        'advice': advice,
        'color': color,
        'bg': bg,
        'sell_score': sell_score,
        'triggers': triggered,
        'checklist': checklist,
        'b_bonus': b_bonus,
    }


@app.route('/api/analysis')
def get_analysis():
    """鏂规B+C锛氭棩鍐呭舰鎬佸尮閰?+ 鎶€鏈寚鏍?""
    with lock:
        data = list(minute_data)
    if not data or len(data) < 5:
        return {'code': STOCK_CODE, 'name': STOCK_NAME, 'status': 'data_insufficient'}
    data = fill_gaps(data)
    bars = data
    n = len(bars)
    latest = bars[-1]
    now_price = latest['close']
    now_time = latest['time']
    now_elapsed = time_to_elapsed(now_time)
    current_to = latest.get('turnover', 0)

    closes = [b['close'] for b in bars]
    vols = [b['vol'] for b in bars]
    amounts = [b['amount'] for b in bars]
    tos = [b.get('turnover', 0) for b in bars]

    intraday_high = max(b['high'] for b in bars)
    high_idx = max(i for i, b in enumerate(bars) if b['high'] == intraday_high)
    high_time = bars[high_idx]['time']

    total_amt = sum(a for a in amounts if a > 0)
    total_vol = sum(v for v in vols if v > 0)
    vwap = total_amt / total_vol if total_vol > 0 else now_price

    rets = []
    for i in range(max(1, n-10), n):
        rets.append(abs((closes[i] - closes[i-1]) / closes[i-1] * 100))
    current_vol = sum(rets) / len(rets) if rets else 0

    # 鈹€鈹€ 鏂规B锛氭棩鍐呭舰鎬佸尮閰?鈹€鈹€
    similar = find_similar_histories(bars)
    # 闄勫甫鏈€鐩镐技鑲＄エ鐨勬敹鐩樹环搴忓垪锛堢敤浜庡墠绔敾鍥撅級
    for s in similar:
        hist = load_stock_detail(s['code'])
        if hist:
            s['price_series'] = [b['c'] for b in hist[:n]]
            s['barlen'] = min(n, len(hist))

    # 鈹€鈹€ 鏂规C锛氭妧鏈寚鏍?鈹€鈹€
    indicators = []

    vwap_deviation = (now_price - vwap) / vwap * 100 if vwap > 0 else 0
    indicators.append({
        'id': 'vwap_deviation', 'name': 'VWAP涔栫鐜?,
        'value': round(vwap_deviation, 2), 'unit': '%',
        'signal': 'bullish' if vwap_deviation > 1 else ('bearish' if vwap_deviation < -1 else 'neutral'),
        'detail': f'褰撳墠浠穥now_price:.2f} vs VWAP{vwap:.2f}锛屽亸绂粄vwap_deviation:+.2f}%'
    })

    if n >= 20:
        vol_ma20 = sum(vols[-21:-1]) / 20
        latest_vol = vols[-1]
        vol_ratio = latest_vol / vol_ma20 if vol_ma20 > 0 else 1
        indicators.append({
            'id': 'volume_anomaly', 'name': '鎴愪氦閲忚剦鍐?,
            'value': round(vol_ratio, 2), 'unit': 'x鍧囧€?,
            'signal': 'volume_spike' if vol_ratio > 2.5 else ('volume_dry' if vol_ratio < 0.3 else 'normal'),
            'detail': f'褰撳墠鍒嗛挓閲弡latest_vol}鎵嬶紝杩?0鍒嗛挓鍧囧€納vol_ma20:.0f}鎵嬶紝鍊嶇巼{vol_ratio:.1f}x'
        })

    if n >= 20:
        ema5 = ema(closes, 5)
        ema20 = ema(closes, 20)
        dif = ema5 - ema20
        indicators.append({
            'id': 'macd', 'name': '鍒嗘椂MACD(5/20)',
            'value': round(dif, 2), 'unit': 'DIF',
            'signal': 'golden' if dif > 0 else 'dead',
            'detail': f'EMA5={ema5:.2f} EMA20={ema20:.2f} DIF={dif:+.2f} {"閲戝弶鈫? if dif>0 else "姝诲弶鈫?}'
        })

    if n >= 5:
        mom5 = (closes[-1] - closes[-5]) / closes[-5] * 100
        indicators.append({
            'id': 'momentum_5min', 'name': '5鍒嗛挓鍔ㄩ噺',
            'value': round(mom5, 2), 'unit': '%',
            'signal': 'bullish' if mom5 > 1 else ('bearish' if mom5 < -1 else 'neutral'),
            'detail': f'5鍒嗛挓鍐呭彉鍖杮mom5:+.2f}%'
        })

    if n >= 30 and tos[-1] > 0:
        to_speed_10 = (tos[-1] - tos[-10]) / 10 if tos[-10] > 0 else 0
        to_speed_30 = (tos[-1] - tos[-30]) / 30 if tos[-30] > 0 else 0
        to_accel = to_speed_10 - to_speed_30
        indicators.append({
            'id': 'turnover_speed', 'name': '鎹㈡墜鍔犻€熷害',
            'value': round(to_accel, 4), 'unit': '%/min虏',
            'signal': 'accelerating' if to_accel > 0.01 else ('decelerating' if to_accel < -0.01 else 'steady'),
            'detail': f'杩?0min閫熷害{to_speed_10:.3f}%/min锛岃繎30min{to_speed_30:.3f}%/min'
        })

    # 鍏抽敭浠蜂綅
    key_levels = []
    ipo_price = 0
    if backtest_data:
        for s in backtest_data.get('all_stocks', []):
            if s['code'] == STOCK_CODE:
                ipo_price = s['ipo_price']
                break
    key_levels.append({'name': '寮€鐩樹环', 'price': bars[0]['open'] if bars else now_price})
    key_levels.append({'name': 'VWAP', 'price': round(vwap, 2)})
    key_levels.append({'name': '鏃ュ唴鏈€楂?, 'price': round(intraday_high, 2), 'time': high_time})
    if ipo_price > 0:
        key_levels.append({'name': '鍙戣浠?, 'price': ipo_price})
    for kl in key_levels:
        kl['distance_pct'] = round((now_price - kl['price']) / kl['price'] * 100, 1)

    # 鈹€鈹€ 缁煎悎寤鸿寮曟搸 鈹€鈹€
    rec = build_recommendation(bars, indicators, similar, now_price, vwap, current_to, intraday_high, high_time, now_elapsed, current_vol, now_time)

    # 瀹炴椂浠锋牸搴忓垪锛堢敤浜庡舰鎬佸姣斿浘锛?
    price_series = [b['close'] for b in bars]
    timeline = [b['time'] for b in bars]

    return {
        'code': STOCK_CODE, 'name': STOCK_NAME,
        'time': now_time, 'elapsed_min': now_elapsed,
        'price': now_price, 'vwap': round(vwap, 2),
        'intraday_high': round(intraday_high, 2), 'high_time': high_time,
        'turnover': round(current_to, 1),
        'price_series': price_series,
        'timeline': timeline,
        'similar_histories': similar,
        'indicators': indicators,
        'key_levels': key_levels,
        'recommendation': rec,
        # 鍥捐〃鏃堕棿鏍囪锛堟柟妗圓+鏂规C鍚堝苟瑙﹀彂锛?
        'mark_time': now_time,
        'mark_price': round(now_price, 2),
        'mark_sell_score': rec['sell_score'],
    }


@app.route('/')
def index():
    response = app.send_static_file('live_920083.html')
    response.headers['Cache-Control'] = 'no-cache, no-store, must-revalidate'
    response.headers['Pragma'] = 'no-cache'
    response.headers['Expires'] = '0'
    return response

@app.route('/analysis')
def analysis_page():
    response = app.send_static_file('analysis.html')
    response.headers['Cache-Control'] = 'no-cache, no-store, must-revalidate'
    response.headers['Pragma'] = 'no-cache'
    response.headers['Expires'] = '0'
    return response


if __name__ == '__main__':
    load_backtest()
    try:
        d = fetch_sina(STOCK_CODE)
        prev_close = d['prev_close']
        print(f'[init] prev_close={prev_close}')
    except Exception as e:
        print(f'[init] fetch_sina failed: {e}')
    init_amt = load_today_history()
    if init_amt is None:
        init_amt = 0
    t = threading.Thread(target=poll_data, args=(init_amt,), daemon=True)
    t.start()
    print(f'Server started 鈫?http://localhost:8090')
    app.run(host='0.0.0.0', port=8090, debug=False, use_reloader=False)
