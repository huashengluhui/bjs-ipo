# 鈹€鈹€ 鍐呭瓨鏁版嵁 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
prev_close = 0
minute_data = []   # [{time, open, high, low, close, vol, amount, cum_vol, turnover}]
minute_start_cum_vol = 0
current_minute = ''
lock = threading.Lock()


def fetch_sina(code):
    """鎷夊彇鏂版氮瀹炴椂琛屾儏锛岃繑鍥?dict"""
    url = f'http://hq.sinajs.cn/list={SINA_PREFIX}{code}'
    req = urllib.request.Request(url, headers={'Referer': 'https://finance.sina.com.cn'})
    resp = urllib.request.urlopen(req, timeout=5).read()
    raw = resp.decode('gbk', errors='replace')
    m = re.search(r'"([^"]*)"', raw)
    if not m:
        raise Exception(f'Parse error: {raw[:80]}')
    f = m.group(1).split(',')
    return {
        'name': f[0],
        'open': float(f[1]),
        'prev_close': float(f[2]),
        'price': float(f[3]),
        'high': float(f[4]),
        'low': float(f[5]),
        'cum_vol': int(f[8]),
        'cum_amt': float(f[9]),
    }


def load_today_history():
    """浠庢柊娴储缁忔媺鍙栦粖鏃?鍒嗛挓K绾垮巻鍙叉暟鎹?""
    global minute_data, current_minute, minute_start_cum_vol
    # 鏂版氮K绾挎牸寮? {day: "YYYY-MM-DD HH:MM:SS", open, high, low, close, volume, amount}
    url = ('https://quotes.sina.cn/cn/api/jsonp_v2.php/data/CN_MarketDataService.getKLineData'
           f'?symbol=bj{STOCK_CODE}&scale=1&ma=no&datalen=500')
    hdrs = {'User-Agent':'Mozilla/5.0','Referer':'https://finance.sina.com.cn/'}
    try:
        req = urllib.request.Request(url, headers=hdrs)
        resp = urllib.request.urlopen(req, timeout=10).read().decode('utf-8', errors='replace')
        # 鏂版氮JSONP鏍煎紡: data([...])
        resp = resp[resp.index('(')+1:resp.rindex(')')] if '(' in resp else resp
        raw_data = json.loads(resp)
        today = time.strftime('%Y-%m-%d')
        data = [row for row in raw_data if row.get('day','').startswith(today)]
        # 濡傛灉浠婂ぉ杩樻病鏁版嵁锛堟湭寮€鐩?闈炰氦鏄撴棩锛夛紝浠庢湰鍦板瓨妗ｅ姞杞?
        if not data and os.path.exists(HISTORY_JSON_PATH):
            print(f'[history] today no bars, loading from {HISTORY_JSON_PATH}')
            data = json.load(open(HISTORY_JSON_PATH, 'r', encoding='utf-8-sig'))
    except Exception as e:
        print(f'[history] online fetch failed: {e}')
        # fallback: 鍔犺浇瀛樻。鐨勪粖鏃绾縅SON
        if os.path.exists(HISTORY_JSON_PATH):
            print(f'[history] loading from {HISTORY_JSON_PATH}')
            data = json.load(open(HISTORY_JSON_PATH, 'r', encoding='utf-8-sig'))
        else:
            print('[history] no saved data either')
            return 0

    if not data:
        print('[history] no klines returned')
        return 0

    cum_vol = 0
    with lock:
        minute_data.clear()
        for row in data:
            # 鍏煎鏂版氮鏍煎紡{day:"YYYY-MM-DD HH:MM:SS",...}鍜屾湰鍦癑SON{time:"HH:MM",...}
            if 'day' in row:
                t = row['day'][11:16]  # 鏂版氮鏍煎紡: 鎴彇"HH:MM"
            else:
                t = row['time']  # 鏈湴JSON鏍煎紡: "HH:MM"
            o = float(row['open'])
            c = float(row['close'])
            h = float(row['high'])
            l = float(row['low'])
            v = int(float(row['volume']))  # 鎴愪氦閲?鑲?
            a = round(float(row['amount']), 2)  # 鎴愪氦棰?
            cum_vol += v
            minute_data.append({
                'time': t,
                'open': round(o, 2),
                'high': round(h, 2),
                'low': round(l, 2),
                'close': round(c, 2),
                'vol': v,
                'amount': a,
                'cum_vol': cum_vol,
                'turnover': round(cum_vol / CIRCULATING_SHARES * 100, 2),
            })
def is_trading_time():
    """鍖椾氦鎵€浜ゆ槗鏃堕棿 9:30-11:30, 13:00-15:00"""
    now = time.localtime()
    ms = now.tm_hour * 60 + now.tm_min
    return (9*60+30 <= ms <= 11*60+30) or (13*60+0 <= ms <= 15*60+0)


def poll_data(init_cum_amt=0):
    """鍚庡彴绾跨▼锛氭瘡3绉掓媺鍙栨暟鎹苟鑱氬悎鍒?鍒嗛挓K绾?""
    global minute_data, current_minute, minute_start_cum_vol, prev_close
    minute_start_cum_amt = init_cum_amt
    while True:
        if not is_trading_time():
            time.sleep(10)
            continue
        try:
            d = fetch_sina(STOCK_CODE)
            prev_close = d['prev_close']
            now = time.strftime('%H:%M')
            cum_vol_raw = d['cum_vol']  # 鏂版氮鍗曚綅: 鍖椾氦鎵€=鑲? 涓婁氦鎵€/绉戝垱鏉?鎵?
            cum_vol = cum_vol_raw * VOL_UNIT
            cum_amt = d['cum_amt']
            price = d['price']

            with lock:
                if current_minute != now:
                    existing_times = {m['time'] for m in minute_data}
                    if now in existing_times:
                        current_minute = now
                        continue
                    # 鈹€鈹€ 濉ˉ涓棿缂哄け鐨勫垎閽?鈹€鈹€
                    if minute_data:
                        last_t = minute_data[-1]['time']
                        expected = next_minute(last_t)
                        gap_count = 0
                        while expected and expected != now and not is_lunch_boundary(last_t, expected) and gap_count < 10:
                            if expected not in existing_times:
                                gap_count += 1
                                minute_data.append({
                                    'time': expected,
                                    'open': minute_data[-1]['close'],
                                    'high': minute_data[-1]['close'],
                                    'low': minute_data[-1]['close'],
                                    'close': minute_data[-1]['close'],
                                    'vol': 0,
                                    'amount': 0,
                                    'cum_vol': minute_data[-1]['cum_vol'],
                                    'turnover': minute_data[-1]['turnover'],
                                })
                                existing_times.add(expected)
                            last_t = expected
                            expected = next_minute(expected)
                        if gap_count:
                            print(f'[poll] filled {gap_count} gap minute(s) ending at {now}')
                    if not minute_data and now != '09:30':
                        minute_data.append({
                            'time': '09:30',
                            'open': d['open'], 'high': d['open'],
                            'low': d['open'], 'close': d['open'],
                            'vol': 0, 'amount': 0, 'cum_vol': 0,
                            'turnover': 0
                        })
                        existing_times.add('09:30')
                    minute_start_cum_vol = cum_vol
                    minute_start_cum_amt = cum_amt
                    current_minute = now
                    minute_data.append({
                        'time': now,
                        'open': price,
                        'high': price,
                        'low': price,
                        'close': price,
                        'vol': 0,
                        'amount': 0,
                        'cum_vol': cum_vol,
                        'turnover': round(cum_vol / CIRCULATING_SHARES * 100, 2),
                    })
                elif minute_data:
                    m = minute_data[-1]
                    m['high'] = round(max(m['high'], price), 2)
                    m['low'] = round(min(m['low'], price), 2)
                    m['close'] = price
                    m['vol'] = max(0, cum_vol - minute_start_cum_vol)
                    m['amount'] = round(max(0, cum_amt - minute_start_cum_amt), 2)
                    m['cum_vol'] = cum_vol
                    m['turnover'] = round(cum_vol / CIRCULATING_SHARES * 100, 2)
        except Exception as e:
            print(f'[poll] {e}')
        time.sleep(3)


# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
#  鍗栧嚭椋庨櫓璇勫垎寮曟搸
# 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?

def compute_risk_score(data, prev_close_val):
    """
    鍩轰簬瀹炴椂鏁版嵁鍜屽巻鍙茶寰嬭绠?0-100 鍗栧嚭椋庨櫓璇勫垎
    0 = 鏈€瀹夊叏锛堟寔鏈夛級锛?00 = 鏈€楂橀闄╋紙鍗栧嚭锛?
    """
    if not data or len(data) < 3:
        return {'score': 50, 'signals': [], 'summary': '鏁版嵁涓嶈冻'}

    bars = data
    n = len(bars)
    latest = bars[-1]
    now_price = latest['close']
    now_time = latest['time']
    now_min = int(now_time.replace(':', ''))
    now_elapsed = 0
    if now_min <= 1130:
        now_elapsed = (now_min // 100 - 9) * 60 + (now_min % 100) - 30
    else:
        now_elapsed = (now_min // 100 - 13) * 60 + (now_min % 100) + 120
    now_elapsed = max(0, now_elapsed)

    current_to = latest.get('turnover', 0)

    # 鏃ュ唴鏈€楂樹环
    intraday_high = max(b['high'] for b in bars)
    high_idx = max(i for i, b in enumerate(bars) if b['high'] == intraday_high)

    # 璁＄畻 VWAP
    total_amt = sum(b['amount'] for b in bars if b['amount'] > 0)
    total_vol = sum(b['vol'] for b in bars if b['vol'] > 0)
    vwap = total_amt / total_vol if total_vol > 0 else now_price

    # 璁＄畻娉㈠姩鐜囷紙杩囧幓10鏍圭殑minute returns std锛?
    closes = [b['close'] for b in bars]
    rets = []
    for i in range(max(1, len(closes)-10), len(closes)):
        rets.append(abs((closes[i] - closes[i-1]) / closes[i-1] * 100))
    current_vol = sum(rets) / len(rets) if rets else 0

    signals = []
    score = 0

    # 鈺愨晲 淇″彿1: 鏈€楂樹环鍑虹幇鏃堕棿 鈺愨晲
    high_time = bars[high_idx]['time']
    high_min = int(high_time.replace(':', ''))
    high_elapsed = 0
    if high_min <= 1130:
        high_elapsed = (high_min // 100 - 9) * 60 + (high_min % 100) - 30
    else:
        high_elapsed = (high_min // 100 - 13) * 60 + (high_min % 100) + 120

    if high_elapsed <= 30:
        score += 25
        signals.append({
            'id': 'early_peak',
            'level': 'warning',
            'label': '鏃╃洏瑙侀《',
            'detail': f'鏈€楂樹环鍑虹幇鍦?{high_time}锛堝紑鐩榹high_elapsed}鍒嗛挓锛夛紝鍘嗗彶50%鏂拌偂鍦ㄦ瑙侀《鍚庡洖钀?,
            'weight': 25,
        })
    elif high_elapsed >= 210:  # 14:00 鍚?
        score -= 10
        signals.append({
            'id': 'late_peak',
            'level': 'positive',
            'label': '灏剧洏寮哄娍',
            'detail': f'鏈€楂樹环鍑虹幇鍦?{high_time}锛屽巻鍙插熬鐩樺垱鏂伴珮鏀剁泭鐣欏瓨鐜?3%',
            'weight': -10,
        })

    # 鈺愨晲 淇″彿2: 浠庢渶楂樹环鍥炴挙 鈺愨晲
    if intraday_high > 0:
        dd_pct = (intraday_high - now_price) / intraday_high * 100
        if dd_pct > 20:
            score += 30
            signals.append({
                'id': 'sharp_dd',
                'level': 'danger',
                'label': '澶у箙鍥炴挙',
                'detail': f'浠庢渶楂樹环 {intraday_high:.2f} 宸插洖钀?{dd_pct:.1f}%锛岃秴杩囧巻鍙?0%鍒嗕綅锛?5%锛?,
                'weight': 30,
            })
        elif dd_pct > 10:
            score += 18
            signals.append({
                'id': 'moderate_dd',
                'level': 'warning',
                'label': '涓瓑鍥炴挙',
                'detail': f'浠庢渶楂樹环鍥炶惤 {dd_pct:.1f}%锛屾帴杩戝巻鍙插钩鍧囧洖鎾わ紙16.6%锛?,
                'weight': 18,
            })
        elif dd_pct > 5:
            score += 8
            signals.append({
                'id': 'mild_dd',
                'level': 'info',
                'label': '杞诲井鍥炴挙',
                'detail': f'浠庢渶楂樹环鍥炶惤 {dd_pct:.1f}%',
                'weight': 8,
            })

    # 鈺愨晲 淇″彿3: 鎹㈡墜鐜囦俊鍙凤紙鍙屽垉鍓戯級鈺愨晲
    #   <40%: 绛圭爜鍒嗘暎锛屽绌哄崥寮?鈫?涓€?
    #   40-70%: 榛勯噾鎷夋槆绐楀彛锛屾诞绛归攣瀹氬崠鐩樻灟绔紝灏戦噺涔板崟鍗冲彲鎺ㄩ珮 鈫?鍔犲垎
    #   70-85%: 椋庨櫓绐楀彛锛屼拱鐩樹篃寮€濮嬫灟绔?鈫?鍑忓垎
    #   >85%: 韪╄笍椋庨櫓锛屼换浣曟寔鏈夎€呮亹鎱岄兘鍙兘寮曞彂璺虫按 鈫?楂樺噺鍒?
    if current_to >= 100:
        score += 28
        signals.append({
            'id': 'overbought_extreme',
            'level': 'danger',
            'label': '鎹㈡墜鐜囨瀬搴﹂ケ鍜?,
            'detail': f'绱鎹㈡墜鐜?{current_to:.1f}%宸茶秴100%锛屽绌哄弻鏂瑰潎宸叉崲鎵嬶紝浠讳竴鏂瑰悜瑙﹀彂閮藉皢鏀惧ぇ',
            'weight': 28,
        })
    elif current_to >= 85:
        score += 18
        signals.append({
            'id': 'overbought',
            'level': 'danger',
            'label': '鎹㈡墜鐜囬ケ鍜?,
            'detail': f'绱鎹㈡墜鐜?{current_to:.1f}%锛屼拱鐩樻灟绔紝瀹规槗韪╄笍',
            'weight': 18,
        })
    elif current_to >= 70:
        score += 10
        signals.append({
            'id': 'turnover_risk',
            'level': 'warning',
            'label': '鎹㈡墜鐜囪繘鍏ラ闄╁尯',
            'detail': f'绱鎹㈡墜鐜?{current_to:.1f}%锛岃秺杩?0%榛勯噾绐楀彛锛屾媺鍗囧姩鍔涘噺寮?,
            'weight': 10,
        })
    elif current_to >= 40:
        score -= 12
        signals.append({
            'id': 'turnover_golden',
            'level': 'positive',
            'label': '榛勯噾鎹㈡墜绐楀彛',
            'detail': f'绱鎹㈡墜鐜?{current_to:.1f}%锛屾诞绛规鍦ㄩ攣瀹氾紝鍗栫洏鏋锛屽皯閲忎拱鍗曞嵆鍙帹楂樹环鏍?,
            'weight': -12,
        })
    elif current_to >= 20:
        score -= 5
        signals.append({
            'id': 'turnover_building',
            'level': 'positive',
            'label': '鎹㈡墜鐜囪搫鍔?,
            'detail': f'绱鎹㈡墜鐜?{current_to:.1f}%锛岀鐮佹鍦ㄩ泦涓紝涓哄悗缁媺鏄囩Н钃勫姩鑳?,
            'weight': -5,
        })

    # 鈺愨晲 淇″彿4: 瓒嬪娍 & VWAP 鈺愨晲
    above_vwap = now_price > vwap
    underwater_count = sum(1 for b in bars[-5:] if b['close'] < vwap)
    if not above_vwap and underwater_count >= 3:
        score += 15
        signals.append({
            'id': 'below_vwap',
            'level': 'warning',
            'label': '璺岀牬VWAP',
            'detail': f'浠锋牸 {now_price:.2f} < VWAP {vwap:.2f}锛岃繎5鍒嗛挓{underwater_count}娆″湪涓嬫柟',
            'weight': 15,
        })
    elif not above_vwap:
        score += 8
        signals.append({
            'id': 'vwap_border',
            'level': 'info',
            'label': 'VWAP闄勮繎',
            'detail': f'浠锋牸 {now_price:.2f} 鐣ヤ綆浜?VWAP {vwap:.2f}',
            'weight': 8,
        })

    # 鈺愨晲 淇″彿5: 寮傚父娉㈠姩 鈺愨晲
    if current_vol > 1.5:
        score += 12
        signals.append({
            'id': 'volatility',
            'level': 'warning',
            'label': '娉㈠姩鍔犲墽',
            'detail': f'杩?0鍒嗛挓骞冲潎娉㈠姩 {current_vol:.2f}%锛堟甯?1.0%锛?,
            'weight': 12,
        })

    # 鈺愨晲 淇″彿6: 鏃堕棿绐楀彛 鈺愨晲
    if now_elapsed >= 180 and now_elapsed < 210:  # 13:30-14:00
        score += 5
        signals.append({
            'id': 'afternoon_slump',
            'level': 'info',
            'label': '鍗堝悗鐤茶蒋鏈?,
            'detail': '涓嬪崍鍓嶅崐娈靛巻鍙叉尝鍔ㄨ緝灏忥紝闇€鍏虫敞鏂瑰悜閫夋嫨',
            'weight': 5,
        })
    elif now_elapsed >= 270:  # 14:52 鍚庯紙鏀剁洏鍓嶏級
        score += 10
        signals.append({
            'id': 'closing_time',
            'level': 'info',
            'label': '涓磋繎鏀剁洏',
            'detail': '璺濇敹鐩樹笉瓒?鍒嗛挓锛岄渶鍋氭渶缁堝喅绛?,
            'weight': 10,
        })

    # 鈺愨晲 淇″彿7: 鍔ㄩ噺琛板噺 鈺愨晲
    if len(closes) >= 10:
        avg5 = sum(closes[-5:]) / 5
        avg10 = sum(closes[-10:-5]) / 5
        if avg10 > 0:
            momentum = (avg5 - avg10) / avg10 * 100
            if momentum < -3:
                score += 12
                signals.append({
                    'id': 'momentum_loss',
                    'level': 'warning',
                    'label': '鍔ㄩ噺琛板噺',
                    'detail': f'杩囧幓5鍒嗛挓鍧囦环鐩告瘮鍓?鍒嗛挓涓嬭穼 {abs(momentum):.1f}%',
                    'weight': 12,
                })
            elif momentum > 3:
                score -= 8
                signals.append({
                    'id': 'momentum_gain',
                    'level': 'positive',
                    'label': '鍔ㄩ噺澧炲己',
                    'detail': f'杩囧幓5鍒嗛挓鍧囦环鐩告瘮鍓?鍒嗛挓涓婃定 {momentum:.1f}%',
                    'weight': -8,
                })

    # 闄愬埗鍒嗘暟鑼冨洿
    score = max(0, min(100, score))

    # 鐢熸垚寤鸿
    if score >= 65:
        action = 'sell'
        summary = '鈿狅笍 楂橀闄?鈥?寤鸿鑰冭檻鍗栧嚭'
    elif score >= 40:
        action = 'caution'
        summary = '鈿?涓瓑椋庨櫓 鈥?瀵嗗垏鍏虫敞'
    elif score >= 20:
        action = 'watch'
        summary = '馃憖 浣庨闄?鈥?鍙寔鏈夎瀵?
    else:
        action = 'hold'
        summary = '鉁?瀹夊叏 鈥?寤鸿鎸佹湁'

    # 鍖归厤鏈€鐩镐技鍘嗗彶鑲＄エ
    similar = find_similar_histories(bars) if backtest_data else []

    return {
        'score': score,
        'action': action,
        'summary': summary,
        'signals': sorted(signals, key=lambda s: abs(s['weight']), reverse=True),
        # 鍥捐〃鏍囪
        'mark_time': now_time,
        'mark_price': round(now_price, 2),
        'mark_score': score,
        'metrics': {
            'vwap': round(vwap, 2),
            'above_vwap': above_vwap,
            'intraday_high': round(intraday_high, 2),
            'dd_from_high_pct': round((intraday_high - now_price) / intraday_high * 100, 1) if intraday_high > 0 else 0,
            'current_to': round(current_to, 1),
            'volatility': round(current_vol, 2),
            'volatility_normal': current_vol <= 1.5,
            'high_time': high_time,
            'high_elapsed': high_elapsed,
            'now_elapsed': now_elapsed,
        },
        'similar_histories': similar,
        'stats_ref': {
            'total_stocks': backtest_data['summary']['total_stocks'] if backtest_data else 58,
            'avg_retention': 79.1,
            'avg_dd': 16.6,
            'early_peak_pct': 50,
            'turnover_golden_window': '40-70%',
            'avg_turnover_40pct_min': 68,
            'avg_turnover_70pct_min': 131,
            'avg_turnover_80pct_min': 170,
        } if backtest_data else None,
    }


def find_similar_histories(current_bars):
    """浠庡巻鍙插簱涓壘鍒颁笌褰撳墠璧板娍鏈€鐩镐技鐨勮偂绁?""
    if not backtest_data or not current_bars or len(current_bars) < 5:
        return []

    current_closes = [b['close'] for b in current_bars]
    current_tos = [b.get('turnover', 0) for b in current_bars]
    n = len(current_closes)

    similarities = []
    for stock in backtest_data['all_stocks']:
        hist_bars = load_stock_detail(stock['code'])
        if not hist_bars or len(hist_bars) < n:
            continue
        # 鍙瘮杈冨墠n鏍筀绾?
        hist_closes = [b['c'] for b in hist_bars[:n]]
        # 褰掍竴鍖栵細鐢↖PO浠锋牸鍋氬熀鍑?
        ipo_price = stock['ipo_price']
        curr_norm = [(c - ipo_price) / ipo_price for c in current_closes]
        hist_norm = [(c - ipo_price) / ipo_price for c in hist_closes]

        # 璁＄畻鐩稿叧绯绘暟
        if len(curr_norm) > 5:
            corr = pearson_corr(curr_norm, hist_norm)
        else:
            corr = 0

        # 鎹㈡墜鐜囩浉浼煎害
        to_diff = abs(stock['total_turnover'] - current_tos[-1]) if current_tos[-1] > 0 else 100

        if corr is not None and not math.isnan(corr):
            similarities.append({
                'code': stock['code'],
                'name': stock['name'],
                'correlation': round(corr, 3),
                'to_diff': round(to_diff, 1),
                'final_gain': stock['actual_gain_pct'],
                'max_gain': stock['max_gain_pct'],
                'high_time': stock['high_time'],
            })

    # 鎸夌浉鍏虫€ф帓搴忥紝鍙栧墠3
    similarities.sort(key=lambda s: s['correlation'], reverse=True)
    top = similarities[:3]
    for s in top:
        if s['correlation'] > 0.6:
            s['significance'] = '楂樼浉浼煎害'
            s['advice'] = f"璇ヨ偂棣栨棩娑▄s['final_gain']:.0f}%锛屾渶楂樻定{s['max_gain']:.0f}%锛坽s['high_time']}瑙侀《锛?
        elif s['correlation'] > 0.3:
            s['significance'] = '涓瓑鐩镐技搴?
            s['advice'] = f"浠呬綔鍙傝€冿細鏈€楂樻定{s['max_gain']:.0f}%锛屾敹鐩樻定{s['final_gain']:.0f}%"

    return [s for s in top if s['correlation'] > 0.3]


def load_stock_detail(code):
    """鍔犺浇鍗曞彧鑲＄エ鐨勮鎯呮暟鎹?""
    path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), f'detail_data_{code}.js')
    if not os.path.exists(path):
        return None
    try:
        with open(path, 'r', encoding='utf-8-sig') as f:
            text = f.read()
        m = re.search(r'const DETAIL_DATA\s*=\s*(\[.*?\]);', text, re.DOTALL)
        if m:
            return json.loads(m.group(1))
    except Exception:
        pass
    return None


def pearson_corr(x, y):
    """Pearson correlation coefficient"""
    n = len(x)
    if n < 3:
        return None
    mean_x = sum(x) / n
    mean_y = sum(y) / n
    num = sum((x[i] - mean_x) * (y[i] - mean_y) for i in range(n))
    den = math.sqrt(sum((xi - mean_x)**2 for xi in x) * sum((yi - mean_y)**2 for yi in y))
    if den == 0:
        return None
    return num / den


